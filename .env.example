# ============================================================
# 绘创前程 — 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---- 基础 ----
HC_ENV=development          # development / production
HC_HOST=0.0.0.0
HC_PORT=8100

# ---- 安全（生产必填） ----
HC_SECRET_KEY=              # JWT 签名密钥，生产环境必须设置（建议 32+ 字符随机串）
HC_ALLOWED_ORIGIN=          # 生产 CORS 允许的前端域名，如 https://example.com

# ---- 时区 ----
HC_TIMEZONE_OFFSET=8        # UTC 偏移小时数，中国为 8

# ---- AI 服务（选填，用于作品智能评分） ----
DASHSCOPE_API_KEY=          # 阿里云通义千问 API Key
CLAUDE_API_KEY=             # Anthropic Claude API Key
